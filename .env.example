# ============================================================
# Dominate Marketing — Environment Variables
# Copy this to .env for local dev. NEVER commit .env to Git.
# On Railway: set these in the Railway dashboard under Variables.
# ============================================================

# ----- Core App -----
SESSION_SECRET=your-random-secret-key-here-min-32-chars
FLASK_ENV=production

# ----- Database (Supabase) -----
# Get this from: Supabase Dashboard > Project Settings > Database > Connection String
# Use the "URI" format — Railway/app will auto-fix the prefix
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ----- OpenAI -----
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Model used for autopilot research + post writing. Must be one your key can
# access (e.g. gpt-4o-mini, gpt-4o, gpt-5.5). Defaults to gpt-4o-mini if unset.
OPENAI_TEXT_MODEL=gpt-5.5
# Image model for AI post images (Plus tier+). Cheaper: gpt-image-1-mini (default).
OPENAI_IMAGE_MODEL=gpt-image-1-mini
# Minimum average quality score (0-10) before a post is regenerated. Default 5.0.
QUALITY_MIN=5.0
# Video generation (Pro tier) — provider key (Veo/Pika/Sora). Dormant until set.
VIDEO_PROVIDER_API_KEY=

# ----- Anthropic (Claude) -----
# https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ----- Google AI (Veo 3 video generation) -----
# https://console.cloud.google.com/
GOOGLE_API_KEY=AIza...

# ----- Google OAuth (login with Google) -----
# https://console.cloud.google.com/apis/credentials
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
# Full callback URL — set this to your Railway domain during initial deploy
# e.g. https://your-app.up.railway.app/auth/google_login/callback
# Then update Google Cloud Console to match
OAUTH_CALLBACK_URL=https://dominatemarketing.ninja/auth/google_login/callback

# ----- Stripe (payments) -----
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe Dashboard > Products
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ----- Admin -----
ADMIN_EMAIL=fredwolfe@gmail.com

# ----- Optional: Enhanced trend research -----
# https://serpapi.com/
SERPAPI_KEY=your-serpapi-key

# ----- Optional: Google Search Console / Places -----
GOOGLE_CUSTOM_SEARCH_CX=your-custom-search-cx

# ============================================================
# Automation Engine — social connectors & behavior
# ------------------------------------------------------------
# Until these OAuth apps are created, clients connect "simulated" accounts and
# posts are marked posted with a SIMULATED marker (the whole pipeline still runs
# and is reviewable). Add real credentials to post for real.
# Facebook app also powers Instagram.
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Force simulation even if keys exist (handy for demos). Leave blank for auto.
AI_SIMULATE=
SOCIAL_SIMULATE=
# Run the automation scheduler inside the web process for local dev (true/false).
# In production the dedicated `worker` process handles this instead.
RUN_SCHEDULER=true
