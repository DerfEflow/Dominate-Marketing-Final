# API Keys Configuration for Campaign Generator
# Copy this file to .env and add your actual API keys

# OpenAI API Key (required for text generation and DALL-E images)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google API Key (required for Gemini/Veo3 video generation)
GOOGLE_API_KEY=your-google-api-key-here

# Google Search API (optional - for competitor analysis)
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here