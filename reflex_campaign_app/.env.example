# API Configuration for Reflex Campaign App
# Copy this file to .env and add your actual API keys

# OpenAI API Key (REQUIRED)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google API Key (REQUIRED for VEO 3 videos)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_API_KEY=your-google-api-key-here

# Google Search API (OPTIONAL - for competitor analysis)
# Get from: https://console.cloud.google.com/apis/library/customsearch.googleapis.com
GOOGLE_SEARCH_API_KEY=your-google-search-api-key-here
GOOGLE_SEARCH_ENGINE_ID=your-search-engine-id-here